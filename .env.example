# =============================================
# WEB3 AUTOPOST - Variables de entorno
# =============================================

# URL de tu ActivePieces (cambiar por tu URL real)
# Local: http://localhost:8080
# Railway: https://tu-app.railway.app
ACTIVEPIECES_WEBHOOK_URL=http://localhost:8080/api/v1/webhooks/WEB3-AUTOPOST-WEBHOOK-ID

# (Las demás conexiones se hacen con login OAuth dentro de ActivePieces)
# No necesitas copiar APIs de Twitter, Instagram, LinkedIn ni Facebook
# Solo inicias sesión dentro de ActivePieces con un clic

# Solo Farcaster requiere una key (gratis en neynar.com)
FARCASTER_API_KEY=
FARCASTER_SIGNER_UUID=

# Blog
NEXT_PUBLIC_SITE_NAME=Web3 AutoPost
NEXT_PUBLIC_SITE_URL=https://web3-autopost.vercel.app
NEXT_PUBLIC_SITE_DESCRIPTION=Plataforma de contenido Web3 para todos
